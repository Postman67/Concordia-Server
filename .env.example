# Server port (default 3000)
PORT=3000

# PostgreSQL connection — only needed when running WITHOUT Docker Compose
DB_HOST=localhost
DB_PORT=5432
DB_NAME=concordia
DB_USER=concordia
DB_PASSWORD=changeme

# REQUIRED: long random secret for signing JWTs
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# CORS — set to your frontend origin in production (e.g. http://localhost:5173)
CLIENT_ORIGIN=*
